<Window x:Class="BugTracker.Client.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bug Tracker - Login" Height="440" Width="460"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="#0f172a">

    <Window.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16" Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="2,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#16213e"
                BorderBrush="#1e293b" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="🐛" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Bug Tracker" Foreground="White"
                           FontSize="18" FontWeight="Medium" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- FORM -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center"
                    HorizontalAlignment="Center" Width="300">

            <TextBlock Text="Welcome back" Foreground="#e2e8f0"
                       FontSize="20" FontWeight="Medium"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="Sign in to your account" Foreground="#64748b"
                       FontSize="13" HorizontalAlignment="Center"
                       Margin="0,0,0,28"/>

            <!-- Username -->
            <TextBlock Text="USERNAME" Style="{StaticResource FieldLabel}"/>
            <Border Background="#1e293b" CornerRadius="10"
                    BorderBrush="#334155" BorderThickness="1"
                    Margin="0,0,0,14">
                <TextBox x:Name="TxtUsername" Height="38"
                         Background="Transparent" Foreground="#e2e8f0"
                         BorderThickness="0" Padding="12,0"
                         FontSize="13" CaretBrush="White"
                         VerticalContentAlignment="Center"/>
            </Border>

            <!-- Password -->
            <TextBlock Text="PASSWORD" Style="{StaticResource FieldLabel}"/>
            <Border Background="#1e293b" CornerRadius="10"
                    BorderBrush="#334155" BorderThickness="1"
                    Margin="0,0,0,6">
                <PasswordBox x:Name="TxtPassword" Height="38"
                             Background="Transparent" Foreground="#e2e8f0"
                             BorderThickness="0" Padding="12,0"
                             FontSize="13"/>
            </Border>

            <!-- Error -->
            <TextBlock x:Name="TxtError" Foreground="#f87171"
                       FontSize="12" TextWrapping="Wrap"
                       Margin="2,0,0,16"/>

            <!-- Login button -->
            <Button Content="Login" Height="42" Margin="0,0,0,8"
                    Style="{StaticResource ActionBtn}"
                    Background="#7c3aed" FontSize="14" FontWeight="SemiBold"
                    Click="BtnLogin_Click"/>

            <!-- Register button -->
            <Button Content="Register as Developer" Height="38"
                    Style="{StaticResource ActionBtn}"
                    Background="#1e293b" FontSize="13"
                    Click="BtnRegister_Click"/>
        </StackPanel>
    </Grid>
</Window>

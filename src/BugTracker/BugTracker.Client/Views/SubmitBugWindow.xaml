<Window x:Class="BugTracker.Client.Views.SubmitBugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Submit New Bug" Height="620" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0f172a">

    <Window.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16" Padding="18,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="2,0,0,5"/>
        </Style>
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1e293b"/>
            <Setter Property="Foreground" Value="#e2e8f0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#0284c7"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#16213e"
                BorderBrush="#1e293b" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                <TextBlock Text="🐞" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Submit Bug" Foreground="White"
                           FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
                <TextBlock Text=" — New Report" Foreground="#64748b"
                           FontSize="16" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- FORM -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,18,24,18">

                <!-- Title -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="TITLE *" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtTitle" Height="38"
                             Style="{StaticResource DarkTextBox}"/>
                </StackPanel>

                <!-- Severity -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="SEVERITY *" Style="{StaticResource FieldLabel}"/>
                    <Border Background="#1e293b" CornerRadius="10"
                            BorderBrush="#334155" BorderThickness="1">
                        <ComboBox x:Name="CmbSeverity"
                                  Height="38" Background="Transparent"
                                  Foreground="#e2e8f0" BorderThickness="0"
                                  Padding="10,0" FontSize="13">
                            <ComboBox.Resources>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="#1e293b"/>
                                    <Setter Property="Foreground" Value="#e2e8f0"/>
                                    <Setter Property="Padding" Value="10,6"/>
                                </Style>
                            </ComboBox.Resources>
                            <ComboBoxItem Content="Low" IsSelected="True"/>
                            <ComboBoxItem Content="Medium"/>
                            <ComboBoxItem Content="High"/>
                            <ComboBoxItem Content="Critical"/>
                        </ComboBox>
                    </Border>
                </StackPanel>

                <!-- Description -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="DESCRIPTION *" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtDescription" Height="88"
                             Style="{StaticResource DarkTextBox}"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <!-- Steps to Reproduce -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="STEPS TO REPRODUCE *" Style="{StaticResource FieldLabel}"/>
                    <Border Background="#1e293b" CornerRadius="12"
                            BorderBrush="#334155" BorderThickness="1">
                        <TextBox x:Name="TxtSteps" Height="88"
                                 Background="Transparent" Foreground="#94a3b8"
                                 BorderThickness="0" Padding="10,8"
                                 FontSize="13" CaretBrush="White"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </StackPanel>

                <!-- Attach Photo -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="📎  Attach Photo" Width="140" Height="34"
                            Style="{StaticResource ActionBtn}"
                            Background="#334155"
                            Click="BtnAttachPhoto_Click"/>
                    <TextBlock x:Name="TxtPhotoName" Foreground="#64748b"
                               FontSize="12" VerticalAlignment="Center"
                               Margin="12,0"/>
                </StackPanel>

                <!-- Error -->
                <TextBlock x:Name="TxtError" Foreground="#f87171"
                           FontSize="12" TextWrapping="Wrap"
                           Margin="2,0,0,14"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="95"
                            Style="{StaticResource ActionBtn}"
                            Background="#374151" Margin="0,0,10,0"
                            Click="BtnCancel_Click"/>
                    <Button Content="🐞  Submit Bug" Width="130"
                            Style="{StaticResource ActionBtn}"
                            Background="#dc2626"
                            Click="BtnSubmit_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

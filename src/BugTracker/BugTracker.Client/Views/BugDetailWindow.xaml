<Window x:Class="BugTracker.Client.Views.BugDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bug Details"
        Height="760"
        Width="850"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#0f172a">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="28">

                <!-- HEADER -->
                <Border Background="#111827"
                        CornerRadius="20"
                        Padding="24"
                        Margin="0,0,0,22">

                    <StackPanel>

                        <!-- TITLE -->
                        <TextBlock x:Name="TxtTitle"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,18"/>

                        <!-- BADGES -->
                        <WrapPanel Margin="0,0,0,16">

                            <Border x:Name="SeverityBadge"
                                    Background="#7f1d1d"
                                    CornerRadius="10"
                                    Padding="12,6"
                                    Margin="0,0,10,0">

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠ "
                                               FontSize="14"
                                               Foreground="#fecaca"/>
                                    <TextBlock x:Name="TxtSeverity"
                                               FontWeight="SemiBold"
                                               Foreground="#fecaca"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="StatusBadge"
                                    Background="#1e3a8a"
                                    CornerRadius="10"
                                    Padding="12,6"
                                    Margin="0,0,10,0">

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="● "
                                               Foreground="#bfdbfe"/>
                                    <TextBlock x:Name="TxtStatus"
                                               FontWeight="SemiBold"
                                               Foreground="#bfdbfe"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#312e81"
                                    CornerRadius="10"
                                    Padding="12,6">

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👤 "
                                               Foreground="#c7d2fe"/>
                                    <TextBlock x:Name="TxtReportedBy"
                                               FontWeight="SemiBold"
                                               Foreground="#c7d2fe"/>
                                </StackPanel>
                            </Border>

                        </WrapPanel>

                        <!-- INFO GRID -->
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Assigned -->
                            <Border Grid.Column="0"
                                    Background="#1f2937"
                                    CornerRadius="14"
                                    Padding="16"
                                    Margin="0,0,10,0">

                                <StackPanel>
                                    <TextBlock Text="Assigned To"
                                               Foreground="#9ca3af"
                                               FontSize="12"
                                               Margin="0,0,0,6"/>

                                    <TextBlock x:Name="TxtAssignedTo"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               FontSize="15"/>
                                </StackPanel>
                            </Border>

                            <!-- Created -->
                            <Border Grid.Column="1"
                                    Background="#1f2937"
                                    CornerRadius="14"
                                    Padding="16">

                                <StackPanel>
                                    <TextBlock Text="Created At"
                                               Foreground="#9ca3af"
                                               FontSize="12"
                                               Margin="0,0,0,6"/>

                                    <TextBlock x:Name="TxtCreatedAt"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               FontSize="15"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- DESCRIPTION -->
                <Border Background="#111827"
                        CornerRadius="20"
                        Padding="22"
                        Margin="0,0,0,22">

                    <StackPanel>

                        <TextBlock Text="Description"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,14"/>

                        <Border Background="#1f2937"
                                CornerRadius="14"
                                Padding="18">

                            <TextBlock x:Name="TxtDescription"
                                       Foreground="#d1d5db"
                                       FontSize="15"
                                       TextWrapping="Wrap"/>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- STEPS -->
                <Border Background="#111827"
                        CornerRadius="20"
                        Padding="22"
                        Margin="0,0,0,22">

                    <StackPanel>

                        <TextBlock Text="Steps to Reproduce"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,14"/>

                        <Border Background="#1f2937"
                                CornerRadius="14"
                                Padding="18">

                            <TextBlock x:Name="TxtSteps"
                                       Foreground="#d1d5db"
                                       FontSize="15"
                                       TextWrapping="Wrap"/>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- PHOTO -->
                <Border Background="#111827"
                        CornerRadius="20"
                        Padding="22">

                    <StackPanel>

                        <TextBlock Text="Attached Screenshot"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,14"/>

                        <Border x:Name="PhotoBorder"
                                Background="#1f2937"
                                CornerRadius="16"
                                Padding="14"
                                Visibility="Collapsed">

                            <Image x:Name="BugPhoto"
                                   MaxHeight="450"
                                   Stretch="Uniform"/>
                        </Border>

                        <TextBlock x:Name="TxtNoPhoto"
                                   Text="No screenshot attached."
                                   Foreground="#6b7280"
                                   FontStyle="Italic"
                                   Margin="5,10,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
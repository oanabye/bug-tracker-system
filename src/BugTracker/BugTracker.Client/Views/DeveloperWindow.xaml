<Window x:Class="BugTracker.Client.Views.DeveloperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bug Tracker - Developer Dashboard"
        Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#0f172a">

    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16" Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabBtnActive" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16" Padding="20,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabBtnInactive" TargetType="Button"
               BasedOn="{StaticResource TabBtnActive}">
            <Setter Property="Foreground" Value="#64748b"/>
        </Style>

        <Style x:Key="BugItemContainer" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#334155"
                                                        CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#16213e"
                BorderBrush="#1e293b" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🐛" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Bug Tracker" Foreground="White"
                               FontSize="18" FontWeight="Medium" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Developer Dashboard" Foreground="#64748b"
                               FontSize="18" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="🚪  Logout"
                        Style="{StaticResource ToolbarBtn}"
                        Background="#dc2626" Width="100"
                        Click="BtnLogout_Click"/>
            </Grid>
        </Border>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="#0f3460"
                BorderBrush="#1e3a5f" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <Button Content="↺  Refresh"
                        Style="{StaticResource ToolbarBtn}"
                        Background="#7c3aed" Width="100" Margin="0,0,8,0"
                        Click="BtnRefresh_Click"/>
                <Button Content="🐞  New Bug"
                        Style="{StaticResource ToolbarBtn}"
                        Background="#dc2626" Width="110" Margin="0,0,8,0"
                        Click="BtnNewBug_Click"/>
                <Button Content="✏️  Update Status"
                        Style="{StaticResource ToolbarBtn}"
                        Background="#d97706" Width="130" Margin="0,0,8,0"
                        Click="BtnUpdateStatus_Click"/>
                <Button Content="🔗  Share"
                        Style="{StaticResource ToolbarBtn}"
                        Background="#0284c7" Width="90" Margin="0,0,8,0"
                        Click="BtnShareBug_Click"/>
                <Button Content="🔔  Notifications"
                        Style="{StaticResource ToolbarBtn}"
                        Background="#059669" Width="130" Margin="0,0,8,0"
                        Click="BtnNotifications_Click"/>
                <TextBlock x:Name="TxtStatus" Foreground="#64748b"
                           VerticalAlignment="Center" FontSize="12" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TABS -->
            <StackPanel Orientation="Horizontal" Margin="16,14,16,0">
                <Button x:Name="BtnTabMyBugs"
                        Content="My Bugs"
                        Width="120"
                        Style="{StaticResource TabBtnActive}"
                        Background="#7c3aed"
                        Margin="0,0,8,0"
                        Click="BtnTabMyBugs_Click"/>
                <Button x:Name="BtnTabAllBugs"
                        Content="All Bugs"
                        Width="120"
                        Style="{StaticResource TabBtnInactive}"
                        Background="#1e293b"
                        Click="BtnTabAllBugs_Click"/>
            </StackPanel>

            <!-- BUG LIST -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="16,14,16,14">
                <ListBox x:Name="BugsListBox"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource BugItemContainer}"
                         SelectionChanged="BugsListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>

                                <!-- Bug Card -->
                                <Border x:Name="CardBorder"
                                        Background="#1e293b"
                                        CornerRadius="22"
                                        Padding="16,13"
                                        BorderThickness="1"
                                        BorderBrush="#1e3a5f">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="46"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Severity emoji avatar -->
                                        <Border Grid.Column="0" Width="42" Height="42"
                                                CornerRadius="21" Background="#0f172a"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding SeverityEmoji}"
                                                       FontSize="20"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Main content -->
                                        <StackPanel Grid.Column="1" Margin="12,0,8,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="#e2e8f0"
                                                           FontSize="14" FontWeight="Medium"
                                                           MaxWidth="320"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding IdLabel}"
                                                           Foreground="#475569" FontSize="11"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0"/>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Description}"
                                                       Foreground="#94a3b8" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,7" MaxWidth="460"/>

                                            <StackPanel Orientation="Horizontal">
                                                <Border CornerRadius="12" Padding="9,3" Margin="0,0,6,0"
                                                        Background="{Binding SeverityBg}">
                                                    <TextBlock Text="{Binding Severity}"
                                                               Foreground="{Binding SeverityFg}"
                                                               FontSize="11" FontWeight="Medium"/>
                                                </Border>
                                                <Border CornerRadius="12" Padding="9,3" Margin="0,0,6,0"
                                                        Background="{Binding StatusBg}">
                                                    <TextBlock Text="{Binding Status}"
                                                               Foreground="{Binding StatusFg}"
                                                               FontSize="11" FontWeight="Medium"/>
                                                </Border>
                                                <Border CornerRadius="12" Padding="9,3"
                                                        Background="#1e1e3f"
                                                        BorderBrush="#3730a3" BorderThickness="1"
                                                        Visibility="{Binding AssignedVisibility}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="👤 " FontSize="10" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding AssignedTo}"
                                                                   Foreground="#c4b5fd" FontSize="11"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Right: date + photo -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding CreatedAt, StringFormat=dd/MM/yyyy}"
                                                       Foreground="#475569" FontSize="11"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat=HH:mm}"
                                                       Foreground="#334155" FontSize="10"
                                                       HorizontalAlignment="Right" Margin="0,1,0,0"/>
                                            <Border CornerRadius="10" Padding="6,2" Margin="0,6,0,0"
                                                    Background="#1e293b" BorderBrush="#334155" BorderThickness="1"
                                                    Visibility="{Binding PhotoVisibility}"
                                                    HorizontalAlignment="Right">
                                                <TextBlock Text="📷 photo" Foreground="#64748b" FontSize="10"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Expandable Detail Panel -->
                                <Border x:Name="DetailPanel"
                                        Background="#0f172a"
                                        CornerRadius="0,0,20,20"
                                        Padding="18,14"
                                        Margin="4,0,4,0"
                                        BorderBrush="#1e3a5f"
                                        BorderThickness="1,0,1,1"
                                        Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisConverter}}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                <TextBlock Text="REPORTED BY" Foreground="#475569"
                                                           FontSize="10" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding ReportedBy}"
                                                           Foreground="#e2e8f0" FontSize="13"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="ASSIGNED TO" Foreground="#475569"
                                                           FontSize="10" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding AssignedToDisplay}"
                                                           Foreground="#e2e8f0" FontSize="13"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="STEPS TO REPRODUCE" Foreground="#475569"
                                                   FontSize="10" Margin="0,12,0,5"/>
                                        <Border Background="#1e293b" CornerRadius="12" Padding="12,10">
                                            <TextBlock Text="{Binding StepsToReproduce}"
                                                       Foreground="#94a3b8" FontSize="12"
                                                       TextWrapping="Wrap" LineHeight="20"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                            </StackPanel>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                    <Setter TargetName="CardBorder" Property="CornerRadius" Value="22,22,0,0"/>
                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#0284c7"/>
                                    <Setter TargetName="CardBorder" Property="Background" Value="#1e3a5f"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

        </Grid>
    </Grid>
</Window>

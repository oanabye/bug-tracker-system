<Window x:Class="BugTracker.Client.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register Developer Account" Height="380" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Background="#0f172a">

    <Window.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16" Padding="18,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="2,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#16213e"
                BorderBrush="#1e293b" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                <TextBlock Text="👤" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Register" Foreground="White"
                           FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
                <TextBlock Text=" — Developer Account" Foreground="#64748b"
                           FontSize="16" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- FORM -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center"
                    HorizontalAlignment="Center" Width="320"
                    Margin="0,10,0,0">

            <!-- Username -->
            <TextBlock Text="USERNAME" Style="{StaticResource FieldLabel}"/>
            <Border Background="#1e293b" CornerRadius="10"
                    BorderBrush="#334155" BorderThickness="1"
                    Margin="0,0,0,14">
                <TextBox x:Name="TxtUsername" Height="38"
                         Background="Transparent" Foreground="#e2e8f0"
                         BorderThickness="0" Padding="12,0"
                         FontSize="13" CaretBrush="White"
                         VerticalContentAlignment="Center"/>
            </Border>

            <!-- Password -->
            <TextBlock Text="PASSWORD" Style="{StaticResource FieldLabel}"/>
            <Border Background="#1e293b" CornerRadius="10"
                    BorderBrush="#334155" BorderThickness="1"
                    Margin="0,0,0,6">
                <PasswordBox x:Name="TxtPassword" Height="38"
                             Background="Transparent" Foreground="#e2e8f0"
                             BorderThickness="0" Padding="12,0"
                             FontSize="13"/>
            </Border>

            <!-- Error -->
            <TextBlock x:Name="TxtError" Foreground="#f87171"
                       FontSize="12" TextWrapping="Wrap"
                       Margin="2,0,0,20"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="95"
                        Style="{StaticResource ActionBtn}"
                        Background="#374151" Margin="0,0,10,0"
                        Click="BtnCancel_Click"/>
                <Button Content="Register" Width="110"
                        Style="{StaticResource ActionBtn}"
                        Background="#7c3aed"
                        Click="BtnRegister_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
